{
  "name": "pla-stock",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "postinstall": "pnpm run cf-typegen",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:deprecated": "oxlint --type-aware -A all -D typescript/no-deprecated",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "depcruise": "dependency-cruiser src",
    "knip": "knip --strict --use-tsconfig-files",
    "check:branch": "node scripts/check-branch.mjs",
    "check:harness": "node scripts/check-harness.mjs",
    "check:workflow-pins": "node scripts/check-workflow-pins.mjs",
    "check:test-coverage": "node scripts/check-test-coverage.mjs --strict",
    "check:parallel": "concurrently -n typecheck,depcruise,knip,harness,deprecated,pins,coverage -c blue,green,magenta,cyan,yellow,white,gray \"pnpm run typecheck\" \"pnpm run depcruise\" \"pnpm run knip\" \"pnpm run check:harness\" \"pnpm run lint:deprecated\" \"pnpm run check:workflow-pins\" \"pnpm run check:test-coverage\"",
    "check": "pnpm lint && pnpm lint:deprecated && pnpm format && pnpm typecheck && pnpm depcruise && pnpm knip && pnpm check:harness && pnpm check:workflow-pins && pnpm check:test-coverage",
    "gen:skill-index": "node scripts/gen-skill-index.mjs",
    "gen:adr-index": "node scripts/gen-adr-index.mjs",
    "verify:ui": "node scripts/verify-ui.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply pla-stock --local",
    "db:migrate:remote": "wrangler d1 migrations apply pla-stock --remote",
    "db:studio": "drizzle-kit studio",
    "db:seed:local": "tsx scripts/seed-local.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.1.7",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.42",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "1.8.0",
    "notistack": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/vite-plugin": "^1.29.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.3.10",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.74.0"
  },
  "pnpm": {
    "minimumReleaseAge": 2880,
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
