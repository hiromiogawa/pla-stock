{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": [
    "src/routeTree.gen.ts",
    "worker-configuration.d.ts",
    "dist",
    ".wrangler",
    ".tanstack",
    "node_modules"
  ]
}
