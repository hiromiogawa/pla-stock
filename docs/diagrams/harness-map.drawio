        <mxCell id="L-trigger-h" value="&lt;b&gt;起動契機 (4 種)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;" vertex="1" parent="L1">
          <mxGeometry x="40" y="650" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="L-t1" value="&lt;b&gt;1. user 入力 (slash command、stakes 別、ADR-0024)&lt;/b&gt; — /dev-complete, /post-review, /design-decision, /rule-cycle は user-only (disable-model-invocation: true、AI auto-trigger 構造的不可)。/dev-start のみ AI auto-trigger 可 (disable-model-invocation: false、stakes 低)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="40" y="690" width="1300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="L-t2" value="&lt;b&gt;2. AI auto-trigger (atomic skill / plugin skill の description マッチ)&lt;/b&gt; — session 開始時に system-reminder で全 skill description が context 注入、AI が状況判断" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="40" y="720" width="1300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="L-t3" value="&lt;b&gt;3. lifecycle event (Claude Code 内蔵)&lt;/b&gt; — session 開始時 system-reminder、settings.json の hooks セクション (PreToolUse / PostToolUse 等で外部 command 実行)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="40" y="750" width="1300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="L-t4" value="&lt;b&gt;4. git event (.husky/ + .github/workflows/)&lt;/b&gt; — commit-msg / pre-commit / pre-push hook、push 時 CI workflow。&lt;b&gt;物理強制&lt;/b&gt; (Claude Code 経路に依存しない)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="40" y="780" width="1300" height="30" as="geometry" />
        </mxCell>

        <mxCell id="L-adr-h" value="&lt;b&gt;関連 ADR (本図の origin)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;" vertex="1" parent="L1">
          <mxGeometry x="40" y="830" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="L-adr-list" value="&lt;b&gt;ADR-0001&lt;/b&gt; Tooling (lint / format / commitlint 採用) — &lt;b&gt;ADR-0007&lt;/b&gt; agent failure rules (FAIL-NNN live log) — &lt;b&gt;ADR-0009&lt;/b&gt; memory MCP decouple (file memory への一本化) — &lt;b&gt;ADR-0011&lt;/b&gt; settings.json 権限ポリシー (10 カテゴリ × deny/ask/allow) — &lt;b&gt;ADR-0018&lt;/b&gt; SSoT 境界 (docs/rules/ ground truth + skill orchestration only) — &lt;b&gt;ADR-0022&lt;/b&gt; claude-handbooks plugin 切出 — &lt;b&gt;ADR-0024&lt;/b&gt; harness 機構再点検 (.claude/rules/ 採用 + commands→skills 統一 + stakes 別 user-only)&lt;br/&gt;&lt;br/&gt;関連 Issue: &lt;b&gt;#158&lt;/b&gt; (Closed、skill 4 機構仕分け Epic) / &lt;b&gt;#170&lt;/b&gt; (Open、開発基盤・品質改善 Epic) / &lt;b&gt;#108&lt;/b&gt; (Open、振り返り発火自動化) / &lt;b&gt;#109&lt;/b&gt; (Open、verify:ui Clerk 認証貫通) / &lt;b&gt;#241&lt;/b&gt; (本 ADR-0024 で完了、harness 再点検)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="40" y="870" width="1320" height="110" as="geometry" />
        </mxCell>

        <mxCell id="L-note-update" value="&lt;b&gt;更新ルール&lt;/b&gt; (docs-freshness の How カテゴリ): skill / command / subagent / hook の追加・削除時に手動更新が必要。SSoT は &lt;b&gt;docs/harness-map.md&lt;/b&gt; (本図と整合) と各 &lt;code&gt;.claude/&amp;lt;tier&amp;gt;/&amp;lt;name&amp;gt;.md&lt;/code&gt; の frontmatter。" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fafafa;strokeColor=#666666;fontSize=11;" vertex="1" parent="L1">
          <mxGeometry x="40" y="1000" width="1320" height="60" as="geometry" />
