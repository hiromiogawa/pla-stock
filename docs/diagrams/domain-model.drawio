        <mxCell id="kits" value="&lt;b style=&quot;font-size:15px&quot;&gt;kits&lt;/b&gt; &lt;font style=&quot;font-size:10px;color:#666&quot;&gt;[master]&lt;/font&gt;&lt;hr/&gt;&lt;b&gt;id&lt;/b&gt; text [PK]&lt;br/&gt;name text&lt;br/&gt;grade enum (HG/RG/EG/MG/PG/other)&lt;br/&gt;scale enum (1/144 | 1/100 | 1/60 | 1/48 | other)&lt;br/&gt;retailPriceYen integer?&lt;br/&gt;boxArtUrl text?" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
