        </mxCell>

        <mxCell id="clerk-note" value="&lt;b&gt;userId&lt;/b&gt; は全テーブルに登場するが、Clerk JWT.sub から取得 (external system、pla-stock DB にテーブル無し)" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
