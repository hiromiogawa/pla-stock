          </mxGeometry>
        </mxCell>
        <mxCell id="L-edge-bold-l" value="&lt;b&gt;太実線&lt;/b&gt; = FK CASCADE (project → project_paint_use のみ schema に onDelete: 'cascade' 明示)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="L1">
