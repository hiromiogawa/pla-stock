        </mxCell>

        <mxCell id="L-note-ledger" value="&lt;b&gt;count + event ledger pattern&lt;/b&gt;&lt;br/&gt;在庫数は count (cache) + events (ledger) の 2 種類で表現。&lt;b&gt;events が SoR (source of record)&lt;/b&gt;、stocks は集計値の cache。&lt;br/&gt;CHECK ≥ 0 + UPSERT batch で整合性確保 (ADR-0007 FAIL-003)。" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff8e1;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="60" y="550" width="640" height="80" as="geometry" />
        </mxCell>

        <mxCell id="L-note-weak" value="&lt;b&gt;weak FK (no .references())&lt;/b&gt;&lt;br/&gt;FSD 同層 import 回避のため、&lt;code&gt;projects.kitId&lt;/code&gt; と &lt;code&gt;kit_events.projectId&lt;/code&gt; は &lt;code&gt;.references()&lt;/code&gt; を付けない。&lt;br/&gt;論理的 1:N だが DB レベルの constraint なし。Drizzle 型は手動 join で繋ぐ。" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="60" y="640" width="640" height="80" as="geometry" />
        </mxCell>

        <mxCell id="L-note-timestamp" value="&lt;b&gt;timestamp の 2 種類区別 (ADR-0008)&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Date (instant)&lt;/b&gt; — &lt;code&gt;createdAt&lt;/code&gt; → &lt;code&gt;integer({ mode: 'timestamp_ms' })&lt;/code&gt; + boundary &lt;code&gt;Date&lt;/code&gt;&lt;br/&gt;&lt;b&gt;'YYYY-MM-DD' (calendar)&lt;/b&gt; — &lt;code&gt;purchasedAt / startedAt / completedAt / takenAt&lt;/code&gt; → &lt;code&gt;text&lt;/code&gt; + boundary &lt;code&gt;string&lt;/code&gt;&lt;br/&gt;native &amp;lt;input type=&quot;date&quot;&amp;gt; の value 形式に合わせて calendar は string で扱う (instant のみ Date)。" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fafafa;strokeColor=#666666;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="60" y="730" width="640" height="100" as="geometry" />
        </mxCell>

        <mxCell id="L-note-mn" value="&lt;b&gt;M:N junction (project_paint_use)&lt;/b&gt;&lt;br/&gt;projects ↔ paints の中間テーブル。専用 entity (&lt;code&gt;src/entities/projectPaintUse/&lt;/code&gt;) として独立。&lt;br/&gt;本 entity だけが cross-entity import (paint + project schema) を許される (ADR-0008)。count 非影響。" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff3e0;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="720" y="550" width="620" height="80" as="geometry" />
        </mxCell>

        <mxCell id="L-note-userid" value="&lt;b&gt;userId (Clerk JWT)&lt;/b&gt;&lt;br/&gt;全テーブルの &lt;code&gt;userId&lt;/code&gt; カラムは Clerk JWT &lt;code&gt;.sub&lt;/code&gt; から取得。&lt;br/&gt;pla-stock DB にはユーザーテーブルが存在しない (Clerk が SSoT)。本図でも entity として表現せず、各テーブルのカラム注釈のみで示す。" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;dashed=1;" vertex="1" parent="L1">
          <mxGeometry x="720" y="640" width="620" height="80" as="geometry" />
        </mxCell>

        <mxCell id="L-note-related" value="&lt;b&gt;関連 ADR / docs&lt;/b&gt;&lt;br/&gt;ADR-0008 (entity schema SSoT、本図の origin) / ADR-0006 (Drizzle + D1) / ADR-0010 (master data seeding) / ADR-0007 FAIL-003 (UPSERT CHECK 評価順)&lt;br/&gt;docs/rules/domain-modeling.md / docs/diagrams/README.md (閲覧 / export 手順)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="L1">
          <mxGeometry x="720" y="730" width="620" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
