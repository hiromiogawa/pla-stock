if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash --shims)" 2>/dev/null || true
fi

# ============================================================================
# Step 1: test (Vitest、約 2 秒で 14 file / 68 case 完走)
# ============================================================================
# pre-commit (check:parallel) では test が走らないため、push 前に最終 gate。
# 失敗時は push reject、CI で検出するより早いフィードバックループ。
echo "▶ pnpm test (push 前 gate、#195)"
pnpm test || exit 1

# ============================================================================
# Step 2: build (vite build + tsc --noEmit、約 30-60 秒)
# ============================================================================
# typecheck (tsc --noEmit) は pre-commit でも走るが、vite bundling 段階 (Cloudflare
# Workers 変換) は pre-commit では検証されない。push 前に最終確認。
# dev server (pnpm dev) 動作中だと port 競合の可能性あり → dev server を止めるか
# CI 任せに留めるか開発者判断 (CI でも build job が走るため二重 gate)。
echo "▶ pnpm build (push 前 gate、#195)"
pnpm build || exit 1

# ============================================================================
# Step 3: UI 変更検出 (画面に出る要素の変更のみ verify:ui の対象とする):
#
# - 検出対象:
#   - src/(views|widgets|components)/ 配下の .tsx / .css / .scss
#     (Presenter component と style。hook の .ts や utility は対象外)
#   - src/(theme|styles)/ 配下の全変更
#     (design token / global style は .ts でも UI に直接影響する)
#
# - 除外対象 (UI 変更ではない):
#   - *.test.{ts,tsx} (hook integration test 等、co-located test)
#   - useXxx.ts のような hook の純粋 logic (画面に出ない)
#   - 型定義 / utility / ドキュメント
#
# - 検出 0 件なら exit 0 (verify:ui 不要)
ui_in_components=$(git diff origin/main...HEAD --name-only 2>/dev/null \
  | grep -E '^src/(views|widgets|components)/' \
  | grep -vE '\.test\.(ts|tsx)$' \
  | grep -E '\.(tsx|css|scss)$' \
  | head -1)

ui_in_design_system=$(git diff origin/main...HEAD --name-only 2>/dev/null \
  | grep -E '^src/(theme|styles)/' \
  | grep -vE '\.test\.(ts|tsx)$' \
  | head -1)

if [ -z "$ui_in_components" ] && [ -z "$ui_in_design_system" ]; then
  exit 0
fi

# UI 変更あり → snapshot artifact が必要
if [ ! -d ".playwright-snapshots" ] || [ -z "$(ls -A .playwright-snapshots 2>/dev/null)" ]; then
  echo "❌ UI 変更が検出されたが .playwright-snapshots が空 or 存在しない"
  echo "   先に dev server を起動 (\`pnpm dev\`) してから \`pnpm verify:ui\` を実行してください"
  echo "   詳細: CLAUDE.md \`## AI 運用ルール\`"
  exit 1
fi

# snapshot 鮮度チェック: 最新 snapshot が最終 commit 時刻より新しいか
last_commit_ts=$(git log -1 --format=%ct HEAD)
newest_snapshot=$(ls -t .playwright-snapshots/*.png 2>/dev/null | head -1)
if [ -z "$newest_snapshot" ]; then
  echo "❌ snapshot ファイルが見つかりません"
  exit 1
fi

# stat: macOS は -f %m, Linux は -c %Y
newest_ts=$(stat -f %m "$newest_snapshot" 2>/dev/null || stat -c %Y "$newest_snapshot" 2>/dev/null)
if [ -z "$newest_ts" ] || [ "$newest_ts" -lt "$last_commit_ts" ]; then
  echo "❌ UI 変更後の screenshot が古い (最終 commit より前のタイムスタンプ)"
  echo "   再度 \`pnpm verify:ui\` を実行してください"
  exit 1
fi

echo "✅ UI 変更 + verify:ui 実行確認 OK"
